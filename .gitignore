# 1. ARCHIVOS DE CREDENCIALES Y CONFIGURACIÓN LOCAL
# Bloquea cualquier archivo donde guardes contraseñas de la base de datos
.env
config.sql
credentials.txt
secrets.json

# 2. RESPALDOS Y VOLCADOS DE BASES DE DATOS (BACKUPS)
# Evita subir tablas gigantescas o datos reales de clientes/usuarios
*.sql.gz
*.sql.tar
backup_*.sql
dump.sql
*backup*.sql

# 3. ARCHIVOS TEMPORALES Y DE CONFIGURACIÓN DE VSCODE
# Evita subir carpetas propias de tu editor de texto o sistema operativo
.vscode/
.DS_Store
Thumbs.db
